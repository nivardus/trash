# Copy to `.env` on the droplet and adjust as needed:
#   cp .env.example .env

# Hostname you point at the droplet via a DNS A/AAAA record. Caddy obtains a
# TLS cert for exactly this name, and the web client connects to wss://<this>.
SERVER_DOMAIN=trash.place

# Which server image tag to run. `latest` tracks main; pin a version (e.g. v0.1.0)
# for reproducible deploys.
IMAGE_TAG=latest
